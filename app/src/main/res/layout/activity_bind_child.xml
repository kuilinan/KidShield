<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/kidshield_background_dark"
    android:padding="24dp">

    <TextView android:id="@+id/textView_title"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:text="绑定孩子"
        android:textColor="@color/kidshield_text_primary"
        android:textSize="28sp" android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView android:id="@+id/textView_hint"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="输入孩子的注册邮箱和你的家长码完成绑定"
        android:textColor="@color/kidshield_text_secondary"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textView_title" />

    <EditText android:id="@+id/editText_child_email"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:hint="孩子邮箱"
        android:inputType="textEmailAddress"
        android:textColor="@color/kidshield_text_primary"
        android:padding="16dp"
        android:background="@drawable/search_bar_background"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textView_hint" />

    <EditText android:id="@+id/editText_parent_code"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="家长码"
        android:inputType="number"
        android:textColor="@color/kidshield_text_primary"
        android:padding="16dp"
        android:background="@drawable/search_bar_background"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/editText_child_email" />

    <Button android:id="@+id/button_bind"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="确认绑定"
        android:paddingVertical="14dp"
        android:backgroundTint="@color/kidshield_blue_primary"
        android:textColor="@android:color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/editText_parent_code" />

    <ProgressBar android:id="@+id/progressBar_bind"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="16dp" android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/button_bind" />
</androidx.constraintlayout.widget.ConstraintLayout>
