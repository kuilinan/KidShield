<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/kidshield_background_dark"
    tools:context=".Activities.ParentDashboardActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 标题栏 -->
            <TextView
                android:id="@+id/textView_dashboard_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="24dp"
                android:text="@string/my_children"
                android:textColor="@color/kidshield_text_primary"
                android:textSize="32sp"
                android:textStyle="bold" />

            <!-- ===== 统计卡片行 ===== -->
            <LinearLayout
                android:id="@+id/layout_stats_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="16dp"
                android:orientation="horizontal"
                android:weightSum="3">

                <!-- 卡片1：已绑定孩子数 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/kidshield_card_blue"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/textView_stat_children_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@android:color/white"
                            android:textSize="28sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="已绑定"
                            android:textColor="@android:color/white"
                            android:textSize="12sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- 卡片2：今日管控时长 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_marginStart="3dp"
                    android:layout_marginEnd="3dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/kidshield_card_green"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/textView_stat_screen_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@android:color/white"
                            android:textSize="28sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="今日管控"
                            android:textColor="@android:color/white"
                            android:textSize="12sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- 卡片3：警报次数 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/kidshield_card_orange"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/textView_stat_alerts"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@android:color/white"
                            android:textSize="28sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="今日告警"
                            android:textColor="@android:color/white"
                            android:textSize="12sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
            <!-- ===== VIVO 保活引导卡片 ===== -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_vivo_keepalive"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="16dp"
                android:visibility="gone"
                app:cardBackgroundColor="#FFF8E1"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                tools:visibility="visible">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚡ VIVO 保活设置"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#E65100" />
                    <TextView
                        android:id="@+id/textView_vivo_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="部分保活选项未配置，点击查看详情"
                        android:textSize="13sp"
                        android:textColor="#795548" />
                    <TextView
                        android:id="@+id/textView_vivo_guide"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:padding="10dp"
                        android:background="#FFECB3"
                        android:textSize="12sp"
                        android:textColor="#5D4037"
                        android:visibility="gone"
                        android:lineSpacingExtra="4dp"
                        tools:visibility="visible" />
                    <Button
                        android:id="@+id/btn_vivo_battery_whitelist"
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:layout_marginTop="8dp"
                        android:text="🔋 加入电池白名单"
                        android:textSize="13sp"
                        android:textColor="@android:color/white"
                        android:background="@drawable/btn_blue_rounded" />
                    <Button
                        android:id="@+id/btn_vivo_autostart"
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:layout_marginTop="6dp"
                        android:text="🚀 开启自启动管理"
                        android:textSize="13sp"
                        android:textColor="@android:color/white"
                        android:background="@drawable/btn_blue_rounded" />
                    <Button
                        android:id="@+id/btn_vivo_lock_clean"
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:layout_marginTop="6dp"
                        android:text="🔒 锁屏清理白名单"
                        android:textSize="13sp"
                        android:textColor="@android:color/white"
                        android:background="@drawable/btn_blue_rounded" />
                    <Button
                        android:id="@+id/btn_vivo_highpower"
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:layout_marginTop="6dp"
                        android:text="🔋 后台高耗电白名单"
                        android:textSize="13sp"
                        android:textColor="@android:color/white"
                        android:background="@drawable/btn_blue_rounded" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <!-- VIVO 引导卡片结束 -->

            <!-- 孩子列表标题 -->
            <TextView
                android:id="@+id/textView_children_section_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="20dp"
                android:text="孩子列表"
                android:textColor="@color/kidshield_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- 进度条 -->
            <ProgressBar
                android:id="@+id/progressBar_dashboard"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:layout_marginTop="20dp"
                android:visibility="gone"
                tools:visibility="visible" />

            <!-- 空状态 -->
            <TextView
                android:id="@+id/textView_empty_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:gravity="center"
                android:text="@string/no_children"
                android:textColor="@color/kidshield_text_secondary"
                android:textSize="16sp"
                android:visibility="gone" />

            <!-- 孩子列表 -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView_children"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_child" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_child"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:contentDescription="绑定孩子"
        android:src="@android:drawable/ic_input_add"
        android:tint="@android:color/white"
        app:backgroundTint="@color/kidshield_blue_primary"
        android:layout_gravity="bottom|end" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
