<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A202C">

    <LinearLayout
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical"
        android:background="#2D3748"
        android:padding="28dp"
        android:radius="16dp"
        android:elevation="8dp">

        <TextView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="⏰"
            android:textSize="32sp"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="当前应用已被限制"
            android:textSize="18sp"
            android:textColor="#E2E8F0"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="使用时间已到，休息一下吧"
            android:textSize="14sp"
            android:textColor="#A0AEC0"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/button_ok"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="知道了"
            android:textSize="16sp"
            android:textColor="@android:color/white"
            android:background="@drawable/btn_blue_rounded" />

        <Button
            android:id="@+id/button_request_unlock"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="8dp"
            android:text="申请加时"
            android:textSize="14sp"
            android:textColor="#4299E1"
            android:background="@android:color/transparent" />

    </LinearLayout>
</RelativeLayout>