<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- 顶部标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="🔒 安全防护检查"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:gravity="center" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="覆盖安装后部分权限可能丢失，请确认以下关键防护已开启"
            android:textSize="14sp"
            android:textColor="#757575"
            android:gravity="center"
            android:lineSpacingExtra="4dp" />

        <!-- 设备管理员卡片 -->
        <LinearLayout
            android:id="@+id/guard_card_device_admin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:padding="16dp"
            android:background="@drawable/card_permission_fail"
            android:elevation="2dp">

            <ImageView
                android:id="@+id/guard_icon_device_admin"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_lock_idle_lock"
                android:layout_gravity="center_vertical" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:orientation="vertical"
                android:layout_gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="设备管理员"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#212121" />

                <TextView
                    android:id="@+id/guard_status_device_admin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="检查中..."
                    android:textSize="13sp" />

            </LinearLayout>

            <Button
                android:id="@+id/guard_btn_device_admin"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="去激活"
                android:textSize="13sp"
                android:background="#1565C0"
                android:textColor="#FFFFFF"
                android:visibility="gone" />
        </LinearLayout>

        <!-- 无障碍服务卡片 -->
        <LinearLayout
            android:id="@+id/guard_card_accessibility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:padding="16dp"
            android:background="@drawable/card_permission_fail"
            android:elevation="2dp">

            <ImageView
                android:id="@+id/guard_icon_accessibility"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_view"
                android:layout_gravity="center_vertical" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:orientation="vertical"
                android:layout_gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="无障碍服务"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#212121" />

                <TextView
                    android:id="@+id/guard_status_accessibility"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="检查中..."
                    android:textSize="13sp" />

            </LinearLayout>

            <Button
                android:id="@+id/guard_btn_accessibility"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="去开启"
                android:textSize="13sp"
                android:background="#1565C0"
                android:textColor="#FFFFFF"
                android:visibility="gone" />
        </LinearLayout>

        <!-- 悬浮窗权限卡片 -->
        <LinearLayout
            android:id="@+id/guard_card_overlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:padding="16dp"
            android:background="@drawable/card_permission_fail"
            android:elevation="2dp">

            <ImageView
                android:id="@+id/guard_icon_overlay"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_camera"
                android:layout_gravity="center_vertical" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:orientation="vertical"
                android:layout_gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="悬浮窗权限"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#212121" />

                <TextView
                    android:id="@+id/guard_status_overlay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="检查中..."
                    android:textSize="13sp" />

            </LinearLayout>

            <Button
                android:id="@+id/guard_btn_overlay"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="去授权"
                android:textSize="13sp"
                android:background="#1565C0"
                android:textColor="#FFFFFF"
                android:visibility="gone" />
        </LinearLayout>

        <!-- 说明文字 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="开启这三项权限后，孩子将无法直接卸载 KidShield，有效保障管控不中断"
            android:textSize="12sp"
            android:textColor="#9E9E9E"
            android:gravity="center"
            android:lineSpacingExtra="3dp" />

        <!-- 继续按钮 -->
        <Button
            android:id="@+id/guard_btn_continue"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:text="检查权限中..."
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/btn_blue_rounded"
            android:textColor="#FFFFFF"
            android:enabled="false"
            android:alpha="0.6f" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="32dp"
            android:text="提示：以上权限在覆盖安装后可能被系统重置，补全后可防止被卸载"
            android:textSize="11sp"
            android:textColor="#BDBDBD"
            android:gravity="center" />

    </LinearLayout>
</ScrollView>
